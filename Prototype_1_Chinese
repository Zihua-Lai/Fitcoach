        </div>
      </div>

      <!-- ══ COACH HOME ══ -->
      <div class="screen" id="screen-coach-home">
        <div class="status-bar"><span>9:41</span><span>●●●</span></div>
        <div class="top-bar">
          <div><div class="tt">我的日历</div><div class="ts">2026年5月</div></div>
          <div style="width:28px;height:28px;border-radius:8px;background:#EEEDFE;display:flex;align-items:center;justify-content:center;font-size:16px;color:#534AB7;cursor:pointer;" onclick="showToast('已添加新时间段')">+</div>
        </div>
        <div class="body">
          <div class="cal-grid">
            <div class="cd">一</div><div class="cd">二</div><div class="cd">三</div><div class="cd">四</div><div class="cd">五</div><div class="cd">六</div><div class="cd">日</div>
            <div class="cd has">4</div><div class="cd">5</div><div class="cd today">6</div><div class="cd">7</div><div class="cd">8</div><div class="cd has">9</div><div class="cd">10</div>
          </div>
          <div class="dv"></div>
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
            <div style="display:flex;align-items:center;gap:4px;"><div style="width:9px;height:9px;border-radius:2px;background:#C0DD97;"></div><span style="font-size:10px;color:#8a8a84;">可用</span></div>
