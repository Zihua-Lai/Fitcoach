<script>
const screens = {
  'splash':          { title: 'Splash screen',        hint: 'Tap Login or Register to begin.' },
  'register':        { title: 'Register',              hint: 'Choose Coach or Student to be routed to the right flow.' },
  'login':           { title: 'Login',                 hint: 'Two quick-login buttons to demo both sides.' },
  'coach-home':      { title: 'Coach — Calendar',      hint: 'Tap any red class block or the upcoming reminder to open the student profile.' },
  'coach-students':  { title: 'Coach — Student list',  hint: 'Tap Amy Smith to see her full profile.' },
  'coach-profile':   { title: 'Coach — Student profile', hint: 'Tap "Edit heatmap ›" or a note card to open the body heatmap editor.' },
  'coach-heatmap':   { title: 'Coach — Body heatmap',  hint: 'Tap any red dot to see its note. Tap the body to simulate adding a new pin.' },
  'coach-recipes':   { title: 'Coach — Recipes',       hint: 'Tap "Confirm" to simulate sending a recipe to a student.' },
  'student-home':    { title: 'Student — Home',        hint: 'Tap "Book" on any time slot. Use the bottom nav to explore all sections.' },
  'student-notes':   { title: 'Student — Body notes',  hint: 'Tap the red dots on the body to read the coach\'s specific note.' },
  'student-recipes': { title: 'Student — Recipes',     hint: 'Read-only view of recipes sent by the coach.' },
  'student-photos':  { title: 'Student — Progress',    hint: 'Tap the photo panels or W1–W8 thumbnails. Use the view buttons.' },
};

let current = 'splash';

function go(id) {
  if (id === current) return;
  const prev = document.getElementById('screen-' + current);
  const next = document.getElementById('screen-' + id);
  if (!next) return;
  prev.classList.remove('active');
  next.classList.add('active');
  current = id;
  document.querySelectorAll('.flow-item').forEach(el => {
    el.classList.toggle('active', el.dataset.screen === id);
  });
  const info = screens[id];
  if (info) {
    document.getElementById('screen-title').textContent = info.title;
    document.getElementById('screen-hint').textContent = info.hint;
  }
}

let toastTimer;
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 2200);
}
</script>
