            <div style="display:flex;align-items:center;gap:4px;"><div style="width:9px;height:9px;border-radius:2px;background:#B5D4F4;"></div><span style="font-size:10px;color:#8a8a84;">私人</span></div>
          </div>
          <div class="sl">今日时间表 — 5月6日</div>
          <div style="display:flex;flex-direction:column;gap:5px;margin-bottom:12px;">
            <div style="display:flex;gap:6px;align-items:stretch;">
              <div style="font-size:9px;color:#8a8a84;width:32px;padding-top:5px;flex-shrink:0;">09:00</div>
              <div style="flex:1;background:#C0DD97;border-radius:7px;padding:7px 10px;"><div style="font-size:10px;font-weight:500;color:#27500A;">可预约</div><div style="font-size:9px;color:#3B6D11;">60 分钟</div></div>
            </div>
