<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FitCoach — Interactive Prototype</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'DM Sans', sans-serif;
  background: #1a1a18;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
}

/* ── OUTER LAYOUT ── */
.stage {
  display: flex;
  gap: 48px;
  align-items: flex-start;
  max-width: 900px;
  width: 100%;
}

/* ── SIDEBAR ── */
.sidebar {
  flex-shrink: 0;
  width: 200px;
  padding-top: 20px;
}

.sidebar-logo {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 32px;
}

.sidebar-logo-icon {
  width: 28px; height: 28px;
  background: #534AB7;
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
}

.sidebar-logo-name {
  font-size: 14px;
  font-weight: 500;
  color: #f5f3ee;
}

.sidebar-label {
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: #5F5E5A;
  margin-bottom: 10px;
  padding-left: 2px;
}

.flow-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 10px;
  border-radius: 8px;
  cursor: pointer;
  margin-bottom: 2px;
  transition: background 0.15s;
}

.flow-item:hover { background: #2c2c2a; }
.flow-item.active { background: #2c2c2a; }

.flow-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}

.flow-name {
  font-size: 12px;
  color: #8a8a84;
  line-height: 1.3;
}

.flow-item.active .flow-name { color: #f5f3ee; }

.flow-section {
  margin-bottom: 20px;
}

.section-badge {
  display: inline-block;
  font-size: 9px;
  font-weight: 500;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  padding: 2px 8px;
  border-radius: 10px;
  margin-bottom: 6px;
}

.badge-coach { background: #EEEDFE; color: #3C3489; }
.badge-student { background: #EAF3DE; color: #27500A; }
.badge-shared { background: #2c2c2a; color: #8a8a84; }

/* ── PHONE FRAME ── */
.phone-wrap {
  flex-shrink: 0;
  position: relative;
}

.device {
  width: 320px;
  height: 640px;
  background: #fff;
  border-radius: 44px;
  border: 8px solid #2c2c2a;
  overflow: hidden;
  position: relative;
  box-shadow: 0 0 0 1px #444441, 0 40px 80px rgba(0,0,0,0.6);
}

.device-notch {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100px;
  height: 22px;
  background: #2c2c2a;
  border-radius: 0 0 14px 14px;
  z-index: 100;
}

/* ── SCREENS ── */
.screen {
  position: absolute;
  inset: 0;
  background: #f5f3ee;
  display: flex;
  flex-direction: column;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s ease;
  overflow: hidden;
}

.screen.active {
  opacity: 1;
  pointer-events: all;
}

/* Slide transition */
.screen.slide-in {
  animation: slideIn 0.25s ease forwards;
}
.screen.slide-out {
  animation: slideOut 0.25s ease forwards;
}
@keyframes slideIn {
  from { transform: translateX(100%); opacity: 0.5; }
  to { transform: translateX(0); opacity: 1; }
}
@keyframes slideOut {
  from { transform: translateX(0); opacity: 1; }
  to { transform: translateX(-30%); opacity: 0; }
}

/* ── COMMON SCREEN PARTS ── */
.status-bar {
  background: #f1efe8;
  padding: 22px 18px 6px;
  display: flex;
  justify-content: space-between;
  font-size: 11px;
  color: #8a8a84;
  flex-shrink: 0;
}

.top-bar {
  padding: 12px 16px 10px;
  border-bottom: 1px solid #eceae3;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
  background: #fff;
}

.tt { font-size: 15px; font-weight: 500; color: #1a1a18; }
.ts { font-size: 11px; color: #8a8a84; }

.body {
  flex: 1;
  overflow-y: auto;
  padding: 14px 16px;
  background: #f5f3ee;
}

.body::-webkit-scrollbar { display: none; }

.sl {
  font-size: 10px;
  font-weight: 500;
  color: #8a8a84;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  margin: 0 0 7px;
}

.dv { height: 1px; background: #eceae3; margin: 10px 0; }

.bottom-nav {
  border-top: 1px solid #eceae3;
  display: flex;
  background: #fff;
  flex-shrink: 0;
  padding-bottom: 8px;
}

.ni {
  flex: 1;
  padding: 8px 4px 4px;
  text-align: center;
  cursor: pointer;
}

.ni-i { font-size: 18px; display: block; }
.ni-l { font-size: 9px; color: #8a8a84; display: block; margin-top: 2px; }
.ni.on .ni-l { color: #534AB7; font-weight: 500; }
.ni-d { width: 4px; height: 4px; border-radius: 50%; margin: 0 auto 1px; }
.ni.on .ni-d { background: #534AB7; }

/* ── SHARED COMPONENTS ── */
.cal-grid { display: grid; grid-template-columns: repeat(7,1fr); gap: 3px; margin: 8px 0; }
.cd { text-align: center; font-size: 10px; padding: 4px 2px; border-radius: 4px; color: #8a8a84; }
.cd.has { background: #EEEDFE; color: #534AB7; font-weight: 500; border-radius: 50%; }
.cd.today { background: #534AB7; color: #fff; font-weight: 500; border-radius: 50%; }

.btn-primary {
  background: #534AB7;
  color: #fff;
  border: none;
  border-radius: 10px;
  font-size: 12px;
  font-weight: 500;
  padding: 10px;
  text-align: center;
  cursor: pointer;
  display: block;
  width: 100%;
  font-family: 'DM Sans', sans-serif;
}

.btn-outline {
  background: transparent;
  color: #534AB7;
  border: 1px solid #534AB7;
  border-radius: 10px;
  font-size: 12px;
  font-weight: 500;
  padding: 10px;
  text-align: center;
  cursor: pointer;
  display: block;
  width: 100%;
  font-family: 'DM Sans', sans-serif;
}

.card {
  background: #fff;
  border-radius: 12px;
  padding: 12px 14px;
  margin-bottom: 8px;
  border: 1px solid #eceae3;
  cursor: pointer;
  transition: border-color 0.15s;
}
.card:hover { border-color: #AFA9EC; }

.nc { background: #FCEBEB; border-radius: 8px; padding: 9px 12px; margin-bottom: 7px; border-left: 2px solid #E24B4A; }
.nc-t { font-size: 11px; font-weight: 500; color: #791F1F; }
.nc-b { font-size: 10px; color: #A32D2D; margin-top: 3px; line-height: 1.4; }

.lrow {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 0;
  border-bottom: 1px solid #eceae3;
  cursor: pointer;
}
.lrow:hover { opacity: 0.75; }
.lrow:last-child { border-bottom: none; }

.avatar {
  width: 36px; height: 36px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 11px; font-weight: 500;
  flex-shrink: 0;
}

.tag {
  font-size: 9px;
  padding: 3px 8px;
  border-radius: 10px;
  font-weight: 500;
  margin-left: auto;
  flex-shrink: 0;
}

/* ── BACK BUTTON ── */
.back-btn {
  display: flex;
  align-items: center;
  gap: 4px;
  cursor: pointer;
  color: #534AB7;
  font-size: 12px;
}

/* ── TOAST ── */
.toast {
  position: absolute;
  bottom: 80px;
  left: 50%;
  transform: translateX(-50%);
  background: #1a1a18;
  color: #f5f3ee;
  font-size: 11px;
  padding: 8px 16px;
  border-radius: 20px;
  white-space: nowrap;
  z-index: 999;
  opacity: 0;
  transition: opacity 0.3s;
  pointer-events: none;
}
.toast.show { opacity: 1; }

/* ── HEATMAP DOTS ── */
.heat-dot {
  cursor: pointer;
  transition: transform 0.15s;
}
.heat-dot:hover { transform: scale(1.2); }

/* ── INPUT BOX ── */
.input-box {
  background: #f1efe8;
  border-radius: 8px;
  padding: 9px 12px;
  font-size: 12px;
  color: #b4b2a9;
  border: 1px solid #eceae3;
  width: 100%;
  font-family: 'DM Sans', sans-serif;
}

/* ── TIME SLOT ── */
.slot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 10px;
  padding: 10px 12px;
  margin-bottom: 7px;
  border: 1px solid #eceae3;
}

.slot-btn {
  background: #534AB7;
  color: #fff;
  border: none;
  border-radius: 7px;
  font-size: 10px;
  font-weight: 500;
  padding: 6px 12px;
  cursor: pointer;
  font-family: 'DM Sans', sans-serif;
  flex-shrink: 0;
}

/* ── ONBOARDING FLOW ── */
.splash-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 40px 24px 32px;
}

/* Sidebar right info */
.right-info {
  flex: 1;
  padding-top: 20px;
  max-width: 260px;
}

.right-info h2 {
  font-family: 'DM Serif Display', serif;
  font-size: 22px;
  color: #f5f3ee;
  margin-bottom: 8px;
  line-height: 1.2;
}

.right-info p {
  font-size: 13px;
  color: #5F5E5A;
  line-height: 1.6;
  margin-bottom: 16px;
}

.hint-pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: #2c2c2a;
  border-radius: 20px;
  padding: 5px 12px;
  font-size: 11px;
  color: #8a8a84;
  margin-bottom: 6px;
}

.tap-indicator {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  color: #5F5E5A;
  margin-top: 8px;
}

.tap-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: #534AB7;
}

@media (max-width: 700px) {
  .stage { flex-direction: column; align-items: center; }
  .sidebar { width: 100%; max-width: 320px; padding-top: 0; }
  .right-info { display: none; }
}
</style>
</head>
<body>

<div class="stage">

  <!-- SIDEBAR NAV -->
  <div class="sidebar">
    <div class="sidebar-logo">
      <div class="sidebar-logo-icon">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <circle cx="7" cy="7" r="5" stroke="#fff" stroke-width="1.5"/>
          <circle cx="7" cy="7" r="2" fill="#fff"/>
        </svg>
      </div>
      <span class="sidebar-logo-name">FitCoach</span>
    </div>

    <div class="flow-section">
      <div class="sidebar-label">Start</div>
      <div class="flow-item active" data-screen="splash" onclick="go('splash')">
        <div class="flow-dot" style="background:#534AB7;"></div>
        <div class="flow-name">Splash screen</div>
      </div>
      <div class="flow-item" data-screen="register" onclick="go('register')">
        <div class="flow-dot" style="background:#534AB7;"></div>
        <div class="flow-name">Register</div>
      </div>
      <div class="flow-item" data-screen="login" onclick="go('login')">
        <div class="flow-dot" style="background:#534AB7;"></div>
        <div class="flow-name">Login</div>
      </div>
    </div>

    <div class="flow-section">
      <div class="section-badge badge-coach">Coach</div>
      <div class="flow-item" data-screen="coach-home" onclick="go('coach-home')">
        <div class="flow-dot" style="background:#534AB7;"></div>
        <div class="flow-name">Calendar home</div>
      </div>
      <div class="flow-item" data-screen="coach-students" onclick="go('coach-students')">
        <div class="flow-dot" style="background:#534AB7;"></div>
        <div class="flow-name">Student list</div>
      </div>
      <div class="flow-item" data-screen="coach-profile" onclick="go('coach-profile')">
        <div class="flow-dot" style="background:#534AB7;"></div>
        <div class="flow-name">Student profile</div>
      </div>
      <div class="flow-item" data-screen="coach-heatmap" onclick="go('coach-heatmap')">
        <div class="flow-dot" style="background:#E24B4A;"></div>
        <div class="flow-name">Body heatmap notes</div>
      </div>
      <div class="flow-item" data-screen="coach-recipes" onclick="go('coach-recipes')">
        <div class="flow-dot" style="background:#534AB7;"></div>
        <div class="flow-name">Recipe management</div>
      </div>
    </div>

    <div class="flow-section">
      <div class="section-badge badge-student">Student</div>
      <div class="flow-item" data-screen="student-home" onclick="go('student-home')">
        <div class="flow-dot" style="background:#3B6D11;"></div>
        <div class="flow-name">Home — book class</div>
      </div>
      <div class="flow-item" data-screen="student-notes" onclick="go('student-notes')">
        <div class="flow-dot" style="background:#E24B4A;"></div>
        <div class="flow-name">Body notes</div>
      </div>
      <div class="flow-item" data-screen="student-recipes" onclick="go('student-recipes')">
        <div class="flow-dot" style="background:#3B6D11;"></div>
        <div class="flow-name">Recipes</div>
      </div>
      <div class="flow-item" data-screen="student-photos" onclick="go('student-photos')">
        <div class="flow-dot" style="background:#3B6D11;"></div>
        <div class="flow-name">Progress photos</div>
      </div>
    </div>
  </div>

  <!-- PHONE -->
  <div class="phone-wrap">
    <div class="device">
      <div class="device-notch"></div>
      <div class="toast" id="toast"></div>

      <!-- ══ SPLASH ══ -->
      <div class="screen active" id="screen-splash">
        <div class="splash-inner">
          <div style="width:60px;height:60px;border-radius:18px;background:#1a1a18;margin-bottom:16px;display:flex;align-items:center;justify-content:center;">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="10" stroke="#f5f3ee" stroke-width="2.5"/><circle cx="14" cy="14" r="4" fill="#f5f3ee"/></svg>
          </div>
          <div style="font-size:22px;font-weight:500;color:#1a1a18;margin-bottom:6px;font-family:'DM Serif Display',serif;">FitCoach</div>
          <div style="font-size:12px;color:#8a8a84;text-align:center;margin-bottom:40px;line-height:1.5;">教练与学员的专属平台</div>
          <button class="btn-primary" style="margin-bottom:10px;" onclick="go('login')">登录</button>
          <button class="btn-outline" onclick="go('register')">注册账号</button>
          <div style="font-size:10px;color:#b4b2a9;margin-top:20px;text-align:center;">继续即表示同意服务条款</div>
        </div>
      </div>

      <!-- ══ REGISTER ══ -->
      <div class="screen" id="screen-register">
        <div class="status-bar"><span>9:41</span><span>●●●</span></div>
        <div class="top-bar">
          <div class="back-btn" onclick="go('splash')">‹ 返回</div>
          <div class="tt">创建账号</div>
          <div style="width:40px;"></div>
        </div>
        <div class="body">
          <div style="font-size:10px;color:#8a8a84;margin-bottom:4px;">姓名</div>
          <div class="input-box" style="margin-bottom:10px;">输入你的名字</div>
          <div style="font-size:10px;color:#8a8a84;margin-bottom:4px;">邮箱</div>
          <div class="input-box" style="margin-bottom:10px;">example@email.com</div>
          <div style="font-size:10px;color:#8a8a84;margin-bottom:4px;">密码</div>
          <div class="input-box" style="margin-bottom:16px;">••••••••</div>
          <div class="sl" style="margin-bottom:8px;">我的身份</div>
          <div style="background:#EEEDFE;border:1.5px solid #534AB7;border-radius:12px;padding:12px 14px;margin-bottom:8px;cursor:pointer;" onclick="go('coach-home')">
            <div style="display:flex;align-items:center;gap:10px;">
              <div style="width:16px;height:16px;border-radius:50%;border:2px solid #534AB7;display:flex;align-items:center;justify-content:center;"><div style="width:7px;height:7px;border-radius:50%;background:#534AB7;"></div></div>
              <div>
                <div style="font-size:12px;font-weight:500;color:#3C3489;">教练</div>
                <div style="font-size:10px;color:#534AB7;">管理学员 · 安排课程</div>
              </div>
            </div>
          </div>
          <div style="background:#f1efe8;border:1px solid #eceae3;border-radius:12px;padding:12px 14px;margin-bottom:16px;cursor:pointer;" onclick="go('student-home')">
            <div style="display:flex;align-items:center;gap:10px;">
              <div style="width:16px;height:16px;border-radius:50%;border:1.5px solid #d4d2ca;"></div>
              <div>
                <div style="font-size:12px;font-weight:500;color:#1a1a18;">学员</div>
                <div style="font-size:10px;color:#8a8a84;">预约课程 · 查看笔记</div>
              </div>
            </div>
          </div>
          <button class="btn-primary" onclick="go('coach-home')">注册</button>
          <div style="text-align:center;margin-top:12px;font-size:11px;color:#8a8a84;">已有账号？<span style="color:#534AB7;cursor:pointer;" onclick="go('login')">登录</span></div>
        </div>
      </div>

      <!-- ══ LOGIN ══ -->
      <div class="screen" id="screen-login">
        <div class="status-bar"><span>9:41</span><span>●●●</span></div>
        <div class="top-bar">
          <div class="back-btn" onclick="go('splash')">‹ 返回</div>
          <div class="tt">登录</div>
          <div style="width:40px;"></div>
        </div>
        <div class="body">
          <div style="font-size:10px;color:#8a8a84;margin-bottom:4px;">邮箱</div>
          <div class="input-box" style="margin-bottom:10px;">example@email.com</div>
          <div style="font-size:10px;color:#8a8a84;margin-bottom:4px;">密码</div>
          <div class="input-box" style="margin-bottom:4px;">••••••••</div>
          <div style="text-align:right;font-size:10px;color:#534AB7;margin-bottom:20px;cursor:pointer;">忘记密码？</div>
